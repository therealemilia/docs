{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "Nordverkehrs",
  "colors": {
    "primary": "#e5383b",
    "light": "#e5383b",
    "dark": "#e5383b"
  },
  "favicon": "https://nordverkehr.xyz/logo.png",
  "navigation": {
    "versions": [
      {
        "version": "d",
        "tabs": [
          {
            "tab": "Einleitung",
            "icon": "book-blank"
          }
        ]
      }
    ]
  },
  "logo": "https://nordverkehr.xyz/fivemlo.png",
  "navbar": {
    "links": [
      {
        "href": "https://noverkehr.xyz",
        "label": "Home"
      },
      {
        "href": "https://forum.nordverkehr.xyz",
        "label": "Forum"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Discord",
      "href": "https://nordverkehr.xyz/discord"
    }
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "decoration": "gradient",
    "color": {
      "dark": "#18181b"
    }
  },
  "thumbnails": {
    "appearance": "dark",
    "fonts": {
      "family": "Outfit"
    }
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": "dark",
    "latex": true
  },
  "icons": {
    "library": "fontawesome"
  },
  "markdown": {
    "schema": false
  },
  "banner": {
    "content": "Die Docs befinden sich gerade im aufbau.",
    "type": "info",
    "color": {
      "light": "#0099ff",
      "dark": "#0072ff"
    },
    "dismissible": true
  }
}
